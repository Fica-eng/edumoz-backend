# ============================================
# EduMoz Backend — Variáveis de Ambiente
# ============================================
# ATENÇÃO: Nunca partilhes este ficheiro!
# No Railway, adiciona estas variáveis em:
# Project → Variables

# Supabase (obtém em supabase.com → Project Settings → API)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_KEY=SEU-ANON-KEY-AQUI

# Servidor
PORT=3000
NODE_ENV=production

# Frontend (para CORS — o teu site GitHub Pages)
FRONTEND_URL=https://fica-eng.github.io
